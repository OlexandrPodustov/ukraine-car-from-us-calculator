{
  "name": "ukraine-car-from-us-calculator",
  "version": "1.0.0",
  "description": "Tool to calculate car from US price",
  "main": "index.html",
  "scripts": {
    "start": "node --disable-warning=ExperimentalWarning server.js",
    "start:py": "python3 -m http.server 5500",
    "test": "jest",
    "lint": "eslint assets/js/**/*.js",
    "lint:fix": "eslint assets/js/**/*.js --fix",
    "format": "prettier --write **/*.{js,css,html}",
    "stylelint": "stylelint assets/css/**/*.css",
    "stylelint:fix": "stylelint assets/css/**/*.css --fix",
    "htmlhint": "htmlhint index.html"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "stylelint": "^16.3.1",
    "stylelint-config-standard": "^36.0.0",
    "htmlhint": "^1.1.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ]
  }
}
